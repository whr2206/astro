---
import '../styles/global.css'; // Path to your global CSS file
---
<script>
    import Alpine from 'alpinejs'; // Import Alpine
    import "../scripts/searchBox.alpine.js";
    Alpine.start(); // Start Alpine after the component has loaded
</script>

<div x-data="searchBox" class="search-box">
    <div class="search-input-container">
      <input type="search" x-model="searchQuery" @input="search" placeholder="Search blog posts..." class="search-input" />
      <button class="search-icon-container" @click="search" aria-label="Search">
        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" height="32px" viewBox="0 -960 960 960" width="32px" fill="#293241">
          <path d="M784-120 532-372q-30 24-69 38t-83 14q-109 0-184.5-75.5T120-580q0-109 75.5-184.5T380-840q109 0 184.5 75.5T640-580q0 44-14 83t-38 69l252 252-56 56ZM380-400q75 0 127.5-52.5T560-580q0-75-52.5-127.5T380-760q-75 0-127.5 52.5T200-580q0 75 52.5 127.5T380-400Z"/>
        </svg>
      </button>
    </div>
  
  </div>

<style>
   .search-box {
       margin-bottom: 2rem;
       width: 100%;
       display: flex;
       align-items: center; /* Fixed typo */
   }

   .search-input-container {
       position: relative;
       width: 100%;
       max-width: 1200px;
   }

   .search-box input[type="search"] {
       border: 1px solid #3d5a80;
       box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
       border-radius: .5rem;
       width: 100%;
       min-height: 3rem;
       padding: 1rem;
       padding-right: 3.5rem; /* Make space for the icon */
       font-size: 1.5rem;
       box-sizing: border-box;
   }

   .search-box input:active,
   .search-box input:focus {
       border: 1px solid #3d5a80;
       outline: none;
   }

   .search-box input:hover {
       border: 1px solid #3d5a80;
       box-shadow: 2px 2px 2px #98c1d9;
   }

   .search-icon-container {
       position: absolute;
       right: 10px;
       top: 50%;
       transform: translateY(-50%);
       background: none;
       border: none;
       cursor: pointer;
       padding: 0;
       display: flex;
       align-items: center;
       justify-content: center;
   }

   .search-icon {
       width: 24px;
       height: 24px;
   }
</style>